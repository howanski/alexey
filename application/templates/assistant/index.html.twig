{% extends 'base.html.twig' %}
{% set breadcrumbs = [
	{'name': 'menu_record'|localised('assistant'), 'href': path('assistant_index')}
	]
%}

{% block pageContentPrimary %}
	{% include 'assistant/_main_selector_buttons.html.twig' with {
		'active_button': 'assistant_index',
	} only %}
{% endblock %}

{% block pageContentSecondary %}
	{% set table_data = {} %}
	{% for chat in chats %}
		{% set chat_view_path = path('assistant_chat_view', {'id': chat.id}) %}
		{% set actions %}
			{% include 'table_action_button.html.twig' with {
				'href': chat_view_path,
				'name': 'view'|localised,
			} only %}
			{% include 'table_action_button.html.twig' with {
				'href': path('assistant_chat_delete', {'id': chat.id}),
				'name': 'delete'|localised,
			} only %}
		{% endset %}

		{% set table_data = table_data|merge([{
            'name': '<a href="' ~ chat_view_path ~ '">' ~ chat.shortName(30) ~ '</a>',
			'status': '<a href="' ~ chat_view_path ~ '">' ~ chat.statusEffective ~ '</a>',
			'actions': actions,
		}]) %}
	{% endfor %}
	{% include 'table.html.twig' with {
		'tableTitle': 'chats'|localised('assistant'),
		'tableHeaders': [
			'title'|localised,
			'status'|localised,
            'actions'|localised,
		],
		'tableData': table_data,
	} only %}

	{% include 'form.html.twig' with {
		'form': form,
		'saveButtonLabel': 'send'|localised
	} only %}

{% endblock %}
