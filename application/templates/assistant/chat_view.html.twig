{% extends 'base.html.twig' %}
{% set breadcrumbs = [
	{'name': 'menu_record'|localised('assistant'), 'href': path('assistant_index')}
	]
%}

{% block javascripts %}
	{{ encore_entry_script_tags('forms-js') }}
	{{ encore_entry_script_tags('assistant-scripts') }}
	<script>
		window.addEventListener("load", (event) => {
	        window.scrollTo({
				top: document.body.scrollHeight,
				left: 0,
				behavior: "smooth",
        	});
		});
	</script>
{% endblock %}

{% block pageContentPrimary %}
	{% include 'assistant/_main_selector_buttons.html.twig' with {
		'active_button': 'assistant_index',
	} only %}
{% endblock %}

{% block pageContentSecondary %}
	{% set show_response_form = true %}
	<div class="flex flex-wrap">
		<div class="w-full px-4">
			<div class="relative flex flex-col min-w-0 break-words bg-nord4 w-full mb-6 shadow-lg rounded">
				<div class="rounded-t mb-0 px-4 py-3 border-0">
					<div class="flex flex-wrap items-center">
						<div class="relative w-full px-4 max-w-full flex-grow flex-1">
							<h3 class="font-semibold text-base text-nord0">
								<i class="fas fa-comments mr-1"></i>
								{{ 'chat'|localised('assistant') }}
							</h3>
						</div>
					</div>
				</div>
				<div class="p-4 space-y-6">
					{% for message_pair in chat.messages %}
						<!-- User message -->
						<div class="flex flex-col">
							<div class="flex items-start gap-3">
								<div class="flex-shrink-0">
									<div class="w-8 h-8 rounded-full bg-nord8 flex items-center justify-center text-nord0">
										<i class="fas fa-user text-sm"></i>
									</div>
								</div>
								<div class="flex-1 min-w-0">
									<div class="bg-nord2 text-nord4 rounded-lg rounded-tl-none px-4 py-3 text-sm whitespace-pre-wrap break-words overflow-y-auto has-md-content">{{ message_pair.request|markdown_to_html }}</div>
								</div>
							</div>
						</div>

						<!-- LLM response -->
						<div class="flex flex-col">
							<div class="flex items-start gap-3">
								<div class="flex-shrink-0">
									<div class="w-8 h-8 rounded-full bg-nord8 flex items-center justify-center text-nord0">
										<i class="fas fa-robot text-sm"></i>
									</div>
								</div>
								<div class="flex-1 min-w-0">
									{% if message_pair.isProcessing %}
										<i class="fas fa-circle-notch animate-spin-5 refresh-page-on-check" data-check-path="{{ path('assistant_ajax_is_processed', {id: message_pair.id}) }}"></i>
										{% set show_response_form = false %}
									{% else %}
										<div class="bg-nord5 text-nord0 rounded-lg rounded-tl-none px-4 py-3 text-sm whitespace-pre-wrap break-words overflow-y-auto has-md-content">{{ message_pair.response|markdown_to_html }}</div>
									{% endif %}
									<div class="bg-nord4 text-right text-nord0 rounded-lg px-4 py-3 text-sm break-words overflow-y-auto">
										{{ message_pair.responder }}
										{% if message_pair.token_usage.promptTokens %}
											↑{{ message_pair.token_usage.promptTokens }}
										{% endif %}
										{% if message_pair.token_usage.completionTokens %}
											↓{{ message_pair.token_usage.completionTokens }}
										{% endif %}
										{% include 'table_action_button_secure.html.twig' with {
											'confirmation': 'you_sure_redo'|localised('assistant'),
											'csrf': csrf_token('redo_chat_' ~ message_pair.id),
											'href': path('assistant_ajax_redo', {id: message_pair.id}),
											'name': '↻',
										} only %}
										{% include 'table_action_button_secure.html.twig' with {
											'confirmation': 'you_sure_delete'|localised,
											'csrf': csrf_token('delete_chat_' ~ message_pair.id),
											'href': path('assistant_chat_delete', {id: message_pair.id}),
											'name': '❌',
										} only %}
									</div>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>
			</div>
		</div>
	</div>

	{% if show_response_form %}
		{% include 'form.html.twig' with {
			'form': form,
			'additionalSecuredButtons': [
				{
					'color': 'nord11',
					'action': path('assistant_chat_delete', {id: id}),
		            'csrf': csrf_token('delete_chat_' ~ id),
					'name': 'delete'|localised,
					'icon': 'fas fa-trash',
					'confirmation': 'you_sure_delete'|localised
				}
			],
			'saveButtonLabel': 'send'|localised
		} only %}
	{% endif %}

{% endblock %}
